<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/llTopControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Switch
            android:id="@+id/swViewMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mode Grafik"
            android:textColor="#FFFFFF"
            android:checked="true"
            android:thumbTint="#BB86FC"
            android:trackTint="#757575"
            android:textStyle="bold"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <Button
            android:id="@+id/btnFullScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ ] FULL SCREEN"
            android:textColor="#000000"
            android:textSize="10sp"
            android:backgroundTint="#BB86FC"/>
    </LinearLayout>

    <RadioGroup
        android:id="@+id/rgPlotSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/llTopControls"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">
        <RadioButton android:id="@+id/rbEsp1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="16dp" android:text="ESP 1" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
        <RadioButton android:id="@+id/rbEsp2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="16dp" android:text="ESP 2" android:textColor="#FFFFFF" android:buttonTint="#448AFF"/>
        <RadioButton android:id="@+id/rbBoth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keduanya" android:textColor="#FFFFFF" android:checked="true" android:buttonTint="#03DAC6"/>
    </RadioGroup>

    <RelativeLayout
        android:id="@+id/rlChartContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rgPlotSelect"
        android:background="#1E1E1E"
        android:padding="4dp">
        
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </RelativeLayout>

    <ScrollView
        android:id="@+id/svConsole"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rgPlotSelect"
        android:visibility="gone"
        android:background="#1E1E1E"
        android:fillViewport="true">
        
        <TextView
            android:id="@+id/tvConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00E676"
            android:padding="16dp"
            android:textSize="12sp"
            android:text="Menunggu data..."
            android:fontFamily="monospace"/>
    </ScrollView>

</RelativeLayout>