<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/llTopControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">

        <Switch
            android:id="@+id/swViewMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mode Grafik "
            android:checked="true"
            android:textStyle="bold"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <Button
            android:id="@+id/btnFullScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ ] FULL SCREEN"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:backgroundTint="#002333"/>
    </LinearLayout>

    <RadioGroup
        android:id="@+id/rgPlotSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/llTopControls"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">
        <RadioButton android:id="@+id/rbEsp1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ESP 1" android:buttonTint="#FF0000"/>
        <RadioButton android:id="@+id/rbEsp2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ESP 2" android:buttonTint="#0000FF"/>
        <RadioButton android:id="@+id/rbBoth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keduanya" android:checked="true"/>
    </RadioGroup>

    <RelativeLayout
        android:id="@+id/rlChartContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rgPlotSelect">
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </RelativeLayout>

    <ScrollView
        android:id="@+id/svConsole"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rgPlotSelect"
        android:visibility="gone"
        android:background="#1E1E1E">
        <TextView
            android:id="@+id/tvConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:padding="8dp"
            android:textSize="12sp"
            android:fontFamily="monospace"/>
    </ScrollView>
</RelativeLayout>
